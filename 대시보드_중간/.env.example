# .env.example
# ────────────────────────────────────────────────────────────────────────
# 이 파일을 복사하여 .env로 저장 후 값을 설정하세요.
# cp .env.example .env
# ────────────────────────────────────────────────────────────────────────

# ── LLM 모드 ─────────────────────────────────────────────────────────
# local  : 로컬 Ollama 사용 (테스트/개발용)
# remote : 외부 Gemma API 서버 사용 (시연/배포용)
LLM_MODE=local

# ── 로컬 Ollama 설정 (LLM_MODE=local 시 사용) ─────────────────────────
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=gemma4:e4b        # ollama list 로 설치된 모델명 확인

# ── 외부 API 설정 (LLM_MODE=remote 시 아래 주석 해제) ─────────────────
# REMOTE_LLM_URL=https://xxxx.ngrok-free.app
# REMOTE_LLM_KEY=YOUR_SECRET_KEY_HERE

# ── 대시보드 인증 키 ──────────────────────────────────────────────────
# DEV_KEY: 개발 환경에서 인증 우회 (변경 금지)
# 운영 배포 시 강력한 랜덤 문자열로 교체 후 Vercel 환경변수에도 동일 설정
DASHBOARD_SECRET_KEY=DEV_KEY
